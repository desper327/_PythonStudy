# Flask 配置
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=chatroom

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_EXPIRE_HOURS=24

# 服务器配置
HOST=0.0.0.0
PORT=5000
DEBUG=True
