//Role_Move_Speed_Expr==================================================================================================================================
// 计算移动速度
int $current_frame = `currentTime -q`;
int $prev_frame = `getAttr pd_con.prevFrame`;
vector $pos_now = `xform -q -ws -t Chest_M`;
if (abs(abs($current_frame) - abs($prev_frame)) < 2)
{
	vector $pos_prev = `getAttr pd_con.prevTranslate`;
	vector $delta = $pos_now - $pos_prev;
	float $distance = mag($delta);
	setAttr pd_con.moveSpeed $distance;
}
else
{
	setAttr pd_con.moveSpeed 0;
}

float $prev_x = $pos_now.x;
float $prev_y = $pos_now.y;
float $prev_z = $pos_now.z;
setAttr pd_con.prevTranslate $prev_x $prev_y $prev_z;
setAttr pd_con.prevFrame $current_frame;










