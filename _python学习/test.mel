

//Cache_Expr==================================================================================================================================
int $startFrame = 101;
int $endFrame = 200; 
Hair_ABCN.time    = $startFrame + ((frame * pd_con.cacheHairSpeed)   % ($endFrame - $startFrame + 2));
Cloth_ABCN.time   = $startFrame + ((frame * pd_con.cacheClothSpeed)  % ($endFrame - $startFrame + 2));
Qun_ABCN.time     = $startFrame + ((frame * pd_con.cacheSkirtSpeed)  % ($endFrame - $startFrame + 2));
PiaoDai_ABCN.time = $startFrame + ((frame * pd_con.cacheRibbonSpeed) % ($endFrame - $startFrame + 2));








//Cloth_Expr==================================================================================================================================
// 衣服解算
C_ErLangShen_Mod_Cloth02_Geo_vnBS.NeiYi_Random = pd_con.cacheClothSwitch / 10;


// 衣服褶皱
float $switch_spine_left = clamp(0, 1, (Spine1_M.rotateX + Spine2_M.rotateX + Chest_M.rotateX) / 60);
float $switch_spine_right = clamp(0, 1, (Spine1_M.rotateX + Spine2_M.rotateX + Chest_M.rotateX) / -60);


// 抬起肩膀之后驱动褶皱会穿帮
// float $switch_scapula_left = clamp(0, 1, FKScapula_L.rotateY / -40);
// float $switch_scapula_right = clamp(0, 1, FKScapula_R.rotateY / -40);
float $switch_scapula_left = 0;
float $switch_scapula_right = 0;

C_ErLangShen_Mod_Cloth02_Geo_vnBS.turn_left = clamp(0, 1, $switch_spine_left + $switch_scapula_left);
C_ErLangShen_Mod_Cloth02_Geo_vnBS.turn_right = clamp(0, 1, $switch_spine_right + $switch_scapula_right);









//Follow_Expr==================================================================================================================================
float $switch = pd_con.otherCollisionSwitch / 10;

// 碰撞Hip
Mi_Ft_Jia_01_fk_ctrl_ofs.rotateZ  = $switch * -90 * max(clamp(0, 1, (Hip_R.rotateZ-15)/75), clamp(0, 1, (Hip_L.rotateZ-15)/75));
Mi_Ft_Jia_01_fk_ctrl_ofs.rotateX  = $switch * -45 * clamp(0, 1, (Hip_R.rotateZ-15)/75) * clamp(0, 1, (1 - (Hip_L.rotateZ-60)/30)) + 45 * clamp(0, 1, (Hip_L.rotateZ-15)/75) * clamp(0, 1, (1 - (Hip_R.rotateZ-60)/30));
Mi_Ft_Jia2_01_fk_ctrl_ofs.rotateZ = $switch * -85 * max(clamp(0, 1, (Hip_R.rotateZ-15)/75), clamp(0, 1, (Hip_L.rotateZ-15)/75));
Mi_Ft_Jia2_01_fk_ctrl_ofs.rotateX = $switch * -45 * clamp(0, 1, (Hip_R.rotateZ-15)/75) * clamp(0, 1, (1 - (Hip_L.rotateZ-60)/30)) + 45 * clamp(0, 1, (Hip_L.rotateZ-15)/75) * clamp(0, 1, (1 - (Hip_R.rotateZ-60)/30));
Mi_Bk_Jia_01_fk_ctrl_ofs.rotateZ  = $switch * 95 * max(clamp(0, 1, (-Hip_R.rotateZ-15)/75), clamp(0, 1, (-Hip_L.rotateZ-15)/75));
Mi_Bk_Jia_01_fk_ctrl_ofs.rotateX  = $switch * 45 * clamp(0, 1, (-Hip_R.rotateZ-15)/75) * clamp(0, 1, (1 - (-Hip_L.rotateZ-60)/30)) + -45 * clamp(0, 1, (-Hip_L.rotateZ-15)/75) * clamp(0, 1, (1 - (-Hip_R.rotateZ-60)/30));

Lf_Ft_Qun_01_fk_ctrl_object_grp1.rotateX = $switch * -88 * clamp(0, 1, (Hip_L.rotateZ-10)/80);
Rt_Ft_Qun_01_fk_ctrl_object_grp1.rotateX = $switch * -88 * clamp(0, 1, (Hip_R.rotateZ-10)/80);
Rt_Qun_01_fk_ctrl_object_grp1.rotateZ    = $switch * -80 * clamp(0, 1, (-Hip_R.rotateY-10)/80);
Lf_Qun_01_fk_ctrl_object_grp1.rotateZ    = $switch * 80 * clamp(0, 1, (-Hip_L.rotateY-10)/80);
Lf_Bk_Qun_01_fk_ctrl_object_grp1.rotateX = $switch * 88 * clamp(0, 1, (-Hip_L.rotateZ-10)/80);
Rt_Bk_Qun_01_fk_ctrl_object_grp1.rotateX = $switch * 88 * clamp(0, 1, (-Hip_R.rotateZ-10)/80);

Lf_Ft_Jia_01_fk_ctrl_object_grp1.rotateX = $switch * -80 * clamp(0, 1, (Hip_L.rotateZ-10)/80);
Lf_Ft_Jia_01_fk_ctrl_object_grp1.rotateZ = $switch * 75 * clamp(0, 1, (-Hip_L.rotateY-10)/80) + 25 * clamp(0, 1, Hip_L.rotateX/30);
Rt_Ft_Jia_01_fk_ctrl_object_grp1.rotateX = $switch * -80 * clamp(0, 1, (Hip_R.rotateZ-10)/80) + -0 * clamp(0, 1, Hip_R.rotateX/30);
Rt_Ft_Jia_01_fk_ctrl_object_grp1.rotateZ = $switch * -75 * clamp(0, 1, (-Hip_R.rotateY-10)/80) + -25 * clamp(0, 1, Hip_R.rotateX/30);

Lf_Bk_Jia_01_fk_ctrl_object_grp1.rotateX = $switch * 80 * clamp(0, 1, (-Hip_L.rotateZ-10)/80);
Lf_Bk_Jia_01_fk_ctrl_object_grp1.rotateZ = $switch * 75 * clamp(0, 1, (-Hip_L.rotateY-10)/80) + 25 * clamp(0, 1, -Hip_L.rotateX/30);
Rt_Bk_Jia_01_fk_ctrl_object_grp1.rotateX = $switch * 80 * clamp(0, 1, (-Hip_R.rotateZ-10)/80);
Rt_Bk_Jia_01_fk_ctrl_object_grp1.rotateZ = $switch * -75 * clamp(0, 1, (-Hip_R.rotateY-10)/80) + -25 * clamp(0, 1, -Hip_R.rotateX/30);

FKyaokai_c_1_L_object_grp1.rotateX  = $switch * -80 * clamp(0, 1, (Hip_L.rotateZ-10)/80) + 5 * clamp(0, 1, (-Hip_L.rotateZ-10)/80);
FKyaokai_c_1_L_object_grp1.rotateZ  = $switch * 15 * clamp(0, 1, (Hip_L.rotateZ-10)/80) + 60 * clamp(0, 1, (-Hip_L.rotateY-10)/80) + 15 * clamp(0, 1, Hip_L.rotateX/30);
FKyaokkai_a_1_L_object_grp1.rotateX = $switch * -15 * clamp(0, 1, (Hip_L.rotateZ-10)/80) + 35 * clamp(0, 1, (-Hip_L.rotateZ-10)/80);
FKyaokkai_a_1_L_object_grp1.rotateZ = $switch * 10 * clamp(0, 1, (Hip_L.rotateZ-10)/80) + 90 * clamp(0, 1, (-Hip_L.rotateY-10)/80) + 5 * clamp(0, 1, Hip_L.rotateX/30) + 20 * clamp(0, 1, (-Hip_L.rotateZ-10)/80);
FKyaokai_b_1_L_object_grp1.rotateX  = $switch * clamp(0, 90, 90 * clamp(0, 1, (-Hip_L.rotateZ-10)/80) + 75 * clamp(0, 1, (-Hip_R.rotateZ-10)/80));
FKyaokai_b_1_L_object_grp1.rotateZ  = $switch * -20 * clamp(0, 1, (-Hip_R.rotateZ-10)/80) * clamp(0, 1, (1-(-Hip_L.rotateZ-60)/30));
FKyaokai_c_1_R_object_grp1.rotateX  = $switch * -80 * clamp(0, 1, (Hip_R.rotateZ-10)/80) + 5 * clamp(0, 1, (-Hip_R.rotateZ-10)/80);
FKyaokai_c_1_R_object_grp1.rotateZ  = $switch * -15 * clamp(0, 1, (Hip_R.rotateZ-10)/80) + -60 * clamp(0, 1, (-Hip_R.rotateY-10)/80) + -15 * clamp(0, 1, Hip_R.rotateX/30);
FKyaokkai_a_1_R_object_grp1.rotateX = $switch * -15 * clamp(0, 1, (Hip_R.rotateZ-10)/80) + 35 * clamp(0, 1, (-Hip_R.rotateZ-10)/80);
FKyaokkai_a_1_R_object_grp1.rotateZ = $switch * -10 * clamp(0, 1, (Hip_R.rotateZ-10)/80) + -90 * clamp(0, 1, (-Hip_R.rotateY-10)/80) + -5 * clamp(0, 1, Hip_R.rotateX/30) + -20 * clamp(0, 1, (-Hip_R.rotateZ-10)/80);
FKyaokai_b_1_R_object_grp1.rotateX  = $switch * clamp(0, 90, 75 * clamp(0, 1, (-Hip_L.rotateZ-10)/80) + 90 * clamp(0, 1, (-Hip_R.rotateZ-10)/80));
FKyaokai_b_1_R_object_grp1.rotateZ  = $switch * 20 * clamp(0, 1, (-Hip_L.rotateZ-10)/80) * clamp(0, 1, (1-(-Hip_R.rotateZ-60)/30));


// 碰撞Knee
Lf_Ft_Qun_4_fk_ctrl_object_grp1.rotateX = $switch * 85 * min(clamp(0, 1, Hip_L.rotateZ / 90), clamp(0, 1, Knee_L.rotateZ / -90));
Rt_Ft_Qun_4_fk_ctrl_object_grp1.rotateX = $switch * 85 * min(clamp(0, 1, Hip_R.rotateZ / 90), clamp(0, 1, Knee_R.rotateZ / -90));


// BS
C_ErLangShen_Mod_Cloth06_03_Geo_vnBS.jack_right = $switch * min(clamp(0, 1, Hip_R.rotateZ / 90), clamp(0, 1, Knee_R.rotateZ / -90));
C_ErLangShen_Mod_Cloth06_03_Geo_vnBS.jack_left = $switch * min(clamp(0, 1, Hip_L.rotateZ / 90), clamp(0, 1, Knee_L.rotateZ / -90));








//Hair_Expr==================================================================================================================================
// 衣服解算
C_ErLangShen_Mod_Hair02_Geo_vnBS.Hair_Cache_GRP = pd_con.cacheHairSwitch / 10;


// Sine
// 计算移动速度
float $move_switch = pd_con.moveSpeed / 100.0;

float $sine_switch = pd_con.sineHairSwitch / 10;
C_ErLangShen_Mod_Hair02_Geo_vnBS.Hair_Sine_GRP = $sine_switch;

Hair02_Sine.offset = frame * (pd_con.sineHairSpeed + $move_switch);
Hair03_Sine.offset = frame * (pd_con.sineHairSpeed + $move_switch);
Hair04_Sine.offset = frame * (pd_con.sineHairSpeed + $move_switch);
Hair05_Sine.offset = frame * (pd_con.sineHairSpeed + $move_switch);

Hair02_Sine.amplitude = pd_con.sineHairAmplitude * 0.05 + $move_switch * 0.2;
Hair03_Sine.amplitude = pd_con.sineHairAmplitude * 0.05 + $move_switch * 0.2;
Hair04_Sine.amplitude = pd_con.sineHairAmplitude * 0.05 + $move_switch * 0.2;
Hair05_Sine.amplitude = pd_con.sineHairAmplitude * 0.05 + $move_switch * 0.2;

Hair02_Sine.wavelength = pd_con.sineHairAmplitude * 0.02 + pd_con.sineHairWavelength * 0.5 + $move_switch * 5;
Hair03_Sine.wavelength = pd_con.sineHairAmplitude * 0.02 + pd_con.sineHairWavelength * 0.5 + $move_switch * 5;
Hair04_Sine.wavelength = pd_con.sineHairAmplitude * 0.02 + pd_con.sineHairWavelength * 0.5 + $move_switch * 5;
Hair05_Sine.wavelength = pd_con.sineHairAmplitude * 0.02 + pd_con.sineHairWavelength * 0.5 + $move_switch * 5;


// Wind
float $wind_power = pd_con.windPower * 3;
float $state_pos = clamp(0, 10, pd_con.windHairState) / 10;
float $state_neg = clamp(0, 10, -pd_con.windHairState) / 10;

// X轴
float $x_switch = pd_con.translateX / 10;
mawei1_M_fk_ctrl_object_grp.rotateZ  = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 3 / 3 - $state_neg * 0 / 3);
mawei2_M_fk_ctrl_object_grp.rotateZ  = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 2 / 3 - $state_neg * 1 / 3);
mawei3_M_fk_ctrl_object_grp.rotateZ  = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 1 / 3 - $state_neg * 2 / 3);
mawei4_M_fk_ctrl_object_grp.rotateZ  = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 0 / 3 - $state_neg * 3 / 3);

pifa1_M_fk_ctrl_object_grp.rotateZ   = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 3 / 3 - $state_neg * 0 / 3);
pifa2_M_fk_ctrl_object_grp.rotateZ   = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 2 / 3 - $state_neg * 1 / 3);
pifa3_M_fk_ctrl_object_grp.rotateZ   = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 1 / 3 - $state_neg * 2 / 3);
pifa4_M_fk_ctrl_object_grp.rotateZ   = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 0 / 3 - $state_neg * 3 / 3);

liuhai1_R_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 3 / 3 - $state_neg * 0 / 3);
liuhai2_R_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 2 / 3 - $state_neg * 1 / 3);
liuhai3_R_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 1 / 3 - $state_neg * 2 / 3);
liuhai4_R_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 0 / 3 - $state_neg * 3 / 3);

bingfa1_R_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 3 / 3 - $state_neg * 0 / 3);
bingfa2_R_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 2 / 3 - $state_neg * 1 / 3);
bingfa3_R_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 1 / 3 - $state_neg * 2 / 3);
bingfa4_R_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 0 / 3 - $state_neg * 3 / 3);

bingfa1_L_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 3 / 3 - $state_neg * 0 / 3);
bingfa2_L_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 2 / 3 - $state_neg * 1 / 3);
bingfa3_L_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 1 / 3 - $state_neg * 2 / 3);
bingfa4_L_fk_ctrl_object_grp.rotateZ = (clamp(0, 1, $x_switch) + -clamp(0, 1, -$x_switch)) * $wind_power * (1 - $state_pos * 0 / 3 - $state_neg * 3 / 3);

// Z轴
float $z_switch = pd_con.translateZ / 10;
mawei1_M_fk_ctrl_object_grp.rotateX  = -$z_switch * $wind_power * (1 - $state_pos * 3 / 3 - $state_neg * 0 / 3);
mawei2_M_fk_ctrl_object_grp.rotateX  = -$z_switch * $wind_power * (1 - $state_pos * 2 / 3 - $state_neg * 1 / 3);
mawei3_M_fk_ctrl_object_grp.rotateX  = -$z_switch * $wind_power * (1 - $state_pos * 1 / 3 - $state_neg * 2 / 3);
mawei4_M_fk_ctrl_object_grp.rotateX  = -$z_switch * $wind_power * (1 - $state_pos * 0 / 3 - $state_neg * 3 / 3);

pifa1_M_fk_ctrl_object_grp.rotateX   = -$z_switch * $wind_power * (1 - $state_pos * 3 / 3 - $state_neg * 0 / 3);
pifa2_M_fk_ctrl_object_grp.rotateX   = -$z_switch * $wind_power * (1 - $state_pos * 2 / 3 - $state_neg * 1 / 3);
pifa3_M_fk_ctrl_object_grp.rotateX   = -$z_switch * $wind_power * (1 - $state_pos * 1 / 3 - $state_neg * 2 / 3);
pifa4_M_fk_ctrl_object_grp.rotateX   = -$z_switch * $wind_power * (1 - $state_pos * 0 / 3 - $state_neg * 3 / 3);

liuhai1_R_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 3 / 3 - $state_neg * 0 / 3);
liuhai2_R_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 2 / 3 - $state_neg * 1 / 3);
liuhai3_R_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 1 / 3 - $state_neg * 2 / 3);
liuhai4_R_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 0 / 3 - $state_neg * 3 / 3);

bingfa1_R_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 3 / 3 - $state_neg * 0 / 3);
bingfa2_R_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 2 / 3 - $state_neg * 1 / 3);
bingfa3_R_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 1 / 3 - $state_neg * 2 / 3);
bingfa4_R_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 0 / 3 - $state_neg * 3 / 3);

bingfa1_L_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 3 / 3 - $state_neg * 0 / 3);
bingfa2_L_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 2 / 3 - $state_neg * 1 / 3);
bingfa3_L_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 1 / 3 - $state_neg * 2 / 3);
bingfa4_L_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos * 0 / 3 - $state_neg * 3 / 3);









//Ribbon_Expr==================================================================================================================================
// 解算开关
float $cache_switch = pd_con.cacheRibbonSwitch / 10;
C_ErLangShen_Mod_Cloth09_02_Geo_vnBS.PiaoDai_Cache_Geo = $cache_switch;


// Sine
// 计算移动速度
float $move_switch = pd_con.moveSpeed / 100.0;

float $sine_switch = pd_con.sineRibbonSwitch / 10;
C_ErLangShen_Mod_Cloth09_02_Geo_vnBS.PiaoDai_Sine_Geo = $sine_switch;

PiaoDai_Lt_Sine.offset = frame * (pd_con.sineRibbonSpeed + $move_switch);
PiaoDai_Rt_Sine.offset = frame * (pd_con.sineRibbonSpeed + $move_switch);

PiaoDai_Lt_Sine.amplitude = pd_con.sineRibbonAmplitude * 0.1 + $move_switch * 0.01;
PiaoDai_Rt_Sine.amplitude = pd_con.sineRibbonAmplitude * 0.1 + $move_switch * 0.01;

PiaoDai_Lt_Sine.wavelength = pd_con.sineRibbonAmplitude * 0.04 + pd_con.sineRibbonWavelength * 0.5 + $move_switch * 0.4;
PiaoDai_Rt_Sine.wavelength = pd_con.sineRibbonAmplitude * 0.04 + pd_con.sineRibbonWavelength * 0.5 + $move_switch * 0.4;


// Wind
float $wind_power = pd_con.windPower * 2;
float $state_pos = clamp(0, 10, pd_con.windRibbonState) / 10;
float $state_neg = clamp(0, 10, -pd_con.windRibbonState) / 10;

// X轴
float $x_switch = pd_con.translateX / 10;
piaodaiR_01_fk_ctrl_object_grp.rotateZ  = $x_switch * $wind_power * (1 - $state_pos *  3 / 3.0 - $state_neg * -3 / 3.0);
piaodaiR_2_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos *  2 / 3.0 - $state_neg * -2 / 3.0);
piaodaiR_3_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos *  1 / 3.0 - $state_neg * -1 / 3.0);
piaodaiR_4_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos *  0 / 3.0 - $state_neg *  0 / 3.0);
piaodaiR_5_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos * -1 / 3.0 - $state_neg *  1 / 3.0);
piaodaiR_6_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos * -6 / 3.0 - $state_neg *  2 / 3.0);
piaodaiR_7_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos *  0 / 3.0 - $state_neg *  3 / 3.0);

piaodaiL_01_fk_ctrl_object_grp.rotateZ  = $x_switch * $wind_power * (1 - $state_pos *  3 / 3.0 - $state_neg * -3 / 3.0);
piaodaiL_2_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos *  2 / 3.0 - $state_neg * -2 / 3.0);
piaodaiL_3_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos *  1 / 3.0 - $state_neg * -1 / 3.0);
piaodaiL_4_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos *  0 / 3.0 - $state_neg *  0 / 3.0);
piaodaiL_5_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos * -1 / 3.0 - $state_neg *  1 / 3.0);
piaodaiL_6_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos * -6 / 3.0 - $state_neg *  2 / 3.0);
piaodaiL_7_fk_ctrl_object_grp.rotateZ   = $x_switch * $wind_power * (1 - $state_pos *  0 / 3.0 - $state_neg *  3 / 3.0);

// Z轴
float $z_switch = pd_con.translateZ / 10;
piaodaiR_01_fk_ctrl_object_grp.rotateX = -$z_switch * $wind_power * (1 - $state_pos *  3 / 3.0 - $state_neg * -3 / 3.0);
